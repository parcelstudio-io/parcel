# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM provider: "ollama" (default) | "openai"
LLM_PROVIDER=ollama
LLM_MODEL=gemma4

# OpenAI (optional cloud fallback; set LLM_PROVIDER=openai to use)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Ollama (default — runs Gemma 4 locally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4

# Sesame CSM voice service (Python sidecar)
CSM_SERVICE_URL=http://localhost:8001
CSM_MODEL=sesame/csm-1b
CSM_MOCK=true
HUGGINGFACE_TOKEN=
WHISPER_MODEL=base
