# Allow recently published transitive deps (e.g. @react-navigation from expo-router).
# Without this, pnpm 10+ minimumReleaseAge can block `pnpm install` on fresh lockfiles.
minimum-release-age=0

# Hoist Expo/RN packages so Metro can resolve them (pnpm + Expo Go).
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@react-navigation/*
