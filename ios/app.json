{
  "expo": {
    "name": "Parcel",
    "slug": "parcel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "parcel",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.parcelstudio.parcel",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Parcel uses the microphone so you can talk to your personal agent.",
        "NSSpeechRecognitionUsageDescription": "Parcel uses speech recognition to transcribe your voice messages to your agent."
      }
    },
    "android": {
      "package": "io.parcelstudio.parcel",
      "adaptiveIcon": {
        "backgroundColor": "#FAF9F6",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#FAF9F6",
          "dark": {
            "backgroundColor": "#141412"
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
